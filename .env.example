# Firebase Web 配置（用于匿名登录；不配也能跑本地模拟推荐）
# 复制本文件为 `.env` 后填写（不要提交真实密钥到公开仓库）

EXPO_PUBLIC_AMAP_KEY=
# Web 地图建议单独使用高德 JS API Key；不填时会回退使用 EXPO_PUBLIC_AMAP_KEY
EXPO_PUBLIC_AMAP_WEB_JS_KEY=
# 高德 JS API 2.0 安全密钥（securityJsCode），网页端渲染真实地图通常需要
EXPO_PUBLIC_AMAP_WEB_SECURITY_JS_CODE=

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
